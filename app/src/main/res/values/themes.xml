<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.XploreNow" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>
        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>
        <!-- Typography: Space Grotesk para títulos y encabezados -->
        <!-- Para activar Space Grotesk real: Android Studio > New > More > Downloadable Font -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.XploreNow.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.XploreNow.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.XploreNow.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.XploreNow.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.XploreNow.TitleMedium</item>
    </style>

    <!-- Encabezados: Space Grotesk (sistema usa sans-serif-medium como fallback) -->
    <style name="TextAppearance.XploreNow.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.XploreNow.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.XploreNow.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.XploreNow.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.XploreNow.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Código de voucher: IBM Plex Mono (sistema usa monospace como fallback) -->
    <style name="TextAppearance.XploreNow.VoucherCode" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Círculo para ShapeableImageView (avatar de perfil) -->
    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Theme overlay para inputs sobre fondo oscuro (login glass card) -->
    <style name="ThemeOverlay.XploreNow.DarkInput" parent="">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorOutline">#80FFFFFF</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnSurfaceVariant">#AAFFFFFF</item>
        <item name="android:textColorHint">#80FFFFFF</item>
    </style>
</resources>
