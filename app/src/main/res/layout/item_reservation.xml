<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="9dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeWidth="1dp"
    app:strokeColor="@color/outline">

    <!-- Layout horizontal: thumbnail + info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="13dp"
        android:gravity="center_vertical">

        <!-- Thumbnail cuadrado con esquinas redondeadas -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="66dp"
            android:layout_height="66dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/iv_reservation_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Info a la derecha -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="13dp">

            <!-- Nombre de la actividad -->
            <TextView
                android:id="@+id/tv_reservation_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/on_surface"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Fecha en monospace -->
            <TextView
                android:id="@+id/tv_reservation_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/ibm_plex_mono"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant" />

            <!-- Personas -->
            <TextView
                android:id="@+id/tv_reservation_people"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/on_surface_variant" />

            <!-- Estado -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="10sp"
                app:chipMinHeight="22dp"
                app:chipStartPadding="6dp"
                app:chipEndPadding="6dp"
                app:ensureMinTouchTargetSize="false" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
