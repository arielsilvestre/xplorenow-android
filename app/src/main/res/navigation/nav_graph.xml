<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- AUTH -->
    <fragment android:id="@+id/loginFragment"
        android:name="com.uade.xplorenow.ui.auth.LoginFragment"
        android:label="Iniciar sesión">
        <action android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment android:id="@+id/registerFragment"
        android:name="com.uade.xplorenow.ui.auth.RegisterFragment"
        android:label="Registrarse">
        <action android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- MAIN (Bottom Nav) -->
    <fragment android:id="@+id/homeFragment"
        android:name="com.uade.xplorenow.ui.home.HomeFragment"
        android:label="Inicio" />

    <fragment android:id="@+id/destinationListFragment"
        android:name="com.uade.xplorenow.ui.destinations.DestinationListFragment"
        android:label="Destinos">
        <action android:id="@+id/action_destinationList_to_detail"
            app:destination="@id/destinationDetailFragment" />
    </fragment>

    <fragment android:id="@+id/destinationDetailFragment"
        android:name="com.uade.xplorenow.ui.destinations.DestinationDetailFragment"
        android:label="Detalle del destino">
        <argument android:name="destinationId"
            app:argType="string" />
    </fragment>

    <fragment android:id="@+id/activityListFragment"
        android:name="com.uade.xplorenow.ui.activities.ActivityListFragment"
        android:label="Actividades">
        <action android:id="@+id/action_activityList_to_detail"
            app:destination="@id/activityDetailFragment" />
    </fragment>

    <fragment android:id="@+id/activityDetailFragment"
        android:name="com.uade.xplorenow.ui.activities.ActivityDetailFragment"
        android:label="Detalle de actividad">
        <argument android:name="activityId"
            app:argType="string" />
        <action android:id="@+id/action_activityDetail_to_reservationCreate"
            app:destination="@id/reservationCreateFragment" />
    </fragment>

    <fragment android:id="@+id/guideListFragment"
        android:name="com.uade.xplorenow.ui.guides.GuideListFragment"
        android:label="Guías" />

    <fragment android:id="@+id/reservationListFragment"
        android:name="com.uade.xplorenow.ui.reservations.ReservationListFragment"
        android:label="Mis reservas">
        <action android:id="@+id/action_reservationList_to_create"
            app:destination="@id/reservationCreateFragment" />
    </fragment>

    <fragment android:id="@+id/reservationCreateFragment"
        android:name="com.uade.xplorenow.ui.reservations.ReservationCreateFragment"
        android:label="Nueva reserva">
        <argument android:name="activityId"
            app:argType="string" />
    </fragment>

    <fragment android:id="@+id/profileFragment"
        android:name="com.uade.xplorenow.ui.profile.ProfileFragment"
        android:label="Mi perfil">
        <action android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action android:id="@+id/action_profile_to_biometric"
            app:destination="@id/biometricFragment" />
    </fragment>

    <fragment android:id="@+id/biometricFragment"
        android:name="com.uade.xplorenow.ui.auth.BiometricFragment"
        android:label="Acceso biometrico" />

</navigation>
